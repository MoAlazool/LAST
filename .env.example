# Environment variables for LectureMate

# Node environment
NODE_ENV=development

# Required: Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Pexels API key (for image search)
PEXELS_API_KEY=

# Optional: Ollama Configuration (for local GPU processing)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Optional: Python command override
PYTHON_CMD=python3

# Optional: Firebase Admin (server-side)
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_SERVICE_ACCOUNT_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: GPU
CUDA_VISIBLE_DEVICES=
